{
  "sourceName": "示例影视源",
  "sourceUrl": "https://example.com",
  "version": 1,
  "enabled": true,
  "sourceGroup": "示例",
  "sourceComment": "这是一个视频源配置示例，展示了完整的规则格式。请替换为实际可用的视频源。",
  "searchRule": {
    "searchUrl": "/search?keyword={{keyword}}&page=1",
    "ruleType": "css",
    "listRule": ".video-list .video-item",
    "titleRule": ".video-title@text",
    "coverRule": ".video-cover@attr:src",
    "urlRule": ".video-link@attr:href",
    "descRule": ".video-desc@text"
  },
  "categoryRule": {
    "categoryUrl": "/type/movie?page={{page}}",
    "ruleType": "css",
    "categoryListRule": ".category-nav a",
    "categoryNameRule": "@text",
    "categoryUrlRule": "@attr:href",
    "videoListRule": ".video-grid .video-card",
    "titleRule": ".card-title@text",
    "coverRule": ".card-poster@attr:src",
    "urlRule": ".card-link@attr:href"
  },
  "detailRule": {
    "ruleType": "css",
    "titleRule": "h1.video-title@text",
    "coverRule": "meta[property='og:image']@attr:content",
    "descRule": ".video-description@text",
    "statusRule": ".video-status@text",
    "episodeListRule": ".episode-list .episode-item",
    "episodeNameRule": ".episode-name@text",
    "episodeUrlRule": ".episode-link@attr:href"
  },
  "playerRule": {
    "ruleType": "jsonpath",
    "playerUrlRule": "$.data.video_url",
    "playerHeaders": {
      "Referer": "https://example.com",
      "User-Agent": "Mozilla/5.0"
    }
  }
}
